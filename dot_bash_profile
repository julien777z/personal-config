# Source shared helpers first, then every *.sh in the shell-functions root.
# The readability guard also protects against a literal '*.sh' when the dir is empty.
for f in "$HOME/.config/shell-functions/shared"/*.sh; do
  [ -r "$f" ] && . "$f"
done
unset f

for f in "$HOME/.config/shell-functions"/*.sh; do
  [ -r "$f" ] && . "$f"
done
unset f

