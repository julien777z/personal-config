# Source shared helpers first, then every *.sh in the shell-functions root.
# (N) is the zsh null-glob qualifier: expand to nothing if the dir is empty or missing.
for f in $HOME/.config/shell-functions/shared/*.sh(N); do
  source "$f"
done
unset f

for f in $HOME/.config/shell-functions/*.sh(N); do
  source "$f"
done
unset f

